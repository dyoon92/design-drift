{
  "name": "@catchdrift/overlay",
  "version": "0.1.0",
  "description": "Drop-in design system coverage overlay for React apps. Press D to see drift.",
  "keywords": ["design-system", "drift", "coverage", "react", "storybook", "figma"],
  "homepage": "https://catchdrift.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyoon92/design-drift"
  },
  "author": "Dave Yoon <dave@catchdrift.ai>",
  "bugs": { "url": "https://github.com/dyoon92/design-drift/issues" },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "npm run build && npx publint ."
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "typescript": "~5.9.3"
  }
}
