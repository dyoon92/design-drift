FIGMA_API_TOKEN=your_figma_personal_access_token_here
CHROMATIC_PROJECT_TOKEN=your_chromatic_project_token_here

# ── AI proxy (recommended for team use) ──────────────────────────────────────
# Start the proxy: npm run proxy
# The proxy keeps your Anthropic API key server-side (not in the browser).
ANTHROPIC_API_KEY=sk-ant-your_key_here
VITE_AI_PROXY_URL=http://localhost:3001

# ── Direct browser AI (dev only, single developer) ───────────────────────────
# If VITE_AI_PROXY_URL is not set, the overlay falls back to direct Anthropic
# access using the key you paste into the overlay's Settings panel.
# The key is stored in localStorage — do not use this in team environments.
